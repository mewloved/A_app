rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 유저 프로필 — 본인만 쓰기, 로그인한 사용자 읽기
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // 친구 목록 — 본인만
      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // 공유 포스트 — 로그인한 사용자 읽기, 본인만 쓰기
    match /shared_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update: if request.auth != null; // 좋아요·댓글 수 업데이트
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      // 댓글 서브컬렉션
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
        allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      }
    }
    // 기존 일기 데이터
    match /users/{userId}/entries/{entryId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == "mewloved@gmail.com"
        && request.auth.uid == userId;
    }
    match /users/{userId}/photoMeta/{dateStr} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
